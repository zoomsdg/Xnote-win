<Window x:Class="XNote.App.NoteEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XNote.App"
        Title="编辑纪事" Height="640" Width="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBox x:Name="TitleBox" Grid.Row="0" FontSize="20" FontWeight="Bold" Padding="6"
                 BorderThickness="0,0,0,1" BorderBrush="#FFDDDDDD"/>

        <!-- 分类 / 置顶 / 时间 -->
        <DockPanel Grid.Row="1" Margin="0,8">
            <TextBlock x:Name="TimeText" DockPanel.Dock="Right" VerticalAlignment="Center"
                       Foreground="{StaticResource Muted}" FontSize="11"/>
            <TextBlock Text="分类：" VerticalAlignment="Center"/>
            <ComboBox x:Name="CategoryCombo" Width="140" DisplayMemberPath="Name" SelectedValuePath="Id"
                      VerticalContentAlignment="Center"/>
            <Button Content="新建分类" Click="NewCategory_Click" Margin="6,0"/>
            <CheckBox x:Name="PinCheck" Content="置顶" VerticalAlignment="Center" Margin="10,0"/>
        </DockPanel>

        <!-- 内容块 -->
        <Border Grid.Row="2" BorderBrush="#FFEDEDED" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                <ItemsControl x:Name="BlockList">
                    <ItemsControl.Resources>
                        <!-- 文本块 -->
                        <DataTemplate DataType="{x:Type local:TextEditBlockVM}">
                            <Border Margin="2,4" Padding="4" Background="#FFFAFAFA" CornerRadius="4">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                                        <Button Content="▲" Click="MoveUp_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="▼" Click="MoveDown_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="✕" Click="DeleteBlock_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                    </StackPanel>
                                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                                             TextWrapping="Wrap" MinHeight="60" BorderThickness="0" Background="Transparent"
                                             VerticalScrollBarVisibility="Auto"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                        <!-- 图片块 -->
                        <DataTemplate DataType="{x:Type local:ImageEditBlockVM}">
                            <Border Margin="2,4" Padding="4" Background="#FFFAFAFA" CornerRadius="4">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                                        <Button Content="▲" Click="MoveUp_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="▼" Click="MoveDown_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="✕" Click="DeleteBlock_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Image Source="{Binding Image}" MaxHeight="280" HorizontalAlignment="Left"
                                               Stretch="Uniform" Cursor="Hand" ToolTip="单击查看大图 / 保存"
                                               MouseLeftButtonUp="ViewImage_Click"/>
                                        <TextBox Text="{Binding Alt, UpdateSourceTrigger=PropertyChanged}" FontSize="11"
                                                 Foreground="{StaticResource Muted}" BorderThickness="0" Background="Transparent"
                                                 Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                        <!-- 音频块 -->
                        <DataTemplate DataType="{x:Type local:AudioEditBlockVM}">
                            <Border Margin="2,4" Padding="4" Background="#FFFAFAFA" CornerRadius="4">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                                        <Button Content="▲" Click="MoveUp_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="▼" Click="MoveDown_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="✕" Click="DeleteBlock_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding PlayLabel}" Click="PlayAudio_Click" MinWidth="120"/>
                                        <TextBlock Text="🎵 音频" Foreground="{StaticResource Muted}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                        <!-- 附件块（任意格式文件；本项目不打开其内容，交给系统程序） -->
                        <DataTemplate DataType="{x:Type local:FileEditBlockVM}">
                            <Border Margin="2,4" Padding="4" Background="#FFFAFAFA" CornerRadius="4">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                                        <Button Content="▲" Click="MoveUp_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="▼" Click="MoveDown_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                        <Button Content="✕" Click="DeleteBlock_Click" Width="26" MinWidth="26" Padding="0" Margin="1"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="20" VerticalAlignment="Center" Margin="4,0,8,0"/>
                                        <StackPanel VerticalAlignment="Center" MaxWidth="320">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding FileName}"/>
                                            <TextBlock Text="{Binding DisplaySize}" FontSize="11"
                                                       Foreground="{StaticResource Muted}"/>
                                        </StackPanel>
                                        <Button Content="打开" Click="OpenFile_Click" Margin="10,0,0,0"
                                                ToolTip="解密到临时目录，用系统默认程序打开"/>
                                        <Button Content="另存为" Click="SaveFileAs_Click" Margin="4,0,0,0"
                                                ToolTip="解密并保存到本机磁盘"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 底部工具栏 -->
        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="＋ 文本" Click="AddText_Click"/>
                <Button Content="＋ 图片" Click="AddImage_Click"/>
                <Button Content="📎 附件" Click="AddFile_Click" ToolTip="挂入任意文件（csv/txt/pdf…），加密保存并随导出携带"/>
                <Button x:Name="RecordBtn" Content="● 录音" Click="Record_Click"/>
                <TextBlock x:Name="RecordStatus" Foreground="Red" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="保存" Click="Save_Click" Background="{StaticResource Accent}" Foreground="White"/>
                <Button Content="取消" IsCancel="True" Click="Cancel_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

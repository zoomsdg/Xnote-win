<Window x:Class="XNote.App.CategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理分类" Height="420" Width="360"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="新建" Click="New_Click"/>
            <Button Content="删除选中" Click="Delete_Click"/>
            <Button Content="关闭" IsCancel="True"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,0,0,6"
                   Text="默认分类（日常/工作/感悟）不可删除；删除其它分类会把其下纪事移到“日常”。"
                   TextWrapping="Wrap"/>
        <ListBox x:Name="List" DisplayMemberPath="Name"/>
    </DockPanel>
</Window>

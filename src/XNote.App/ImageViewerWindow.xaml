<Window x:Class="XNote.App.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查看图片" Height="720" Width="960"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFF7F9FC" Padding="8,6"
                BorderBrush="#FFE0E0E0" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock x:Name="Info" DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource Muted}" Margin="10,0"/>
                <Button Content="－" Click="ZoomOut_Click" ToolTip="缩小" Width="34" MinWidth="34"/>
                <Button Content="＋" Click="ZoomIn_Click" ToolTip="放大" Width="34" MinWidth="34"/>
                <Button Content="适应窗口" Click="Fit_Click"/>
                <Button Content="原始大小" Click="Actual_Click"/>
                <Button Content="💾 保存图片" Click="Save_Click" Background="{StaticResource Accent}" Foreground="White"/>
            </DockPanel>
        </Border>
        <ScrollViewer x:Name="Scroll" Background="#FF2B2B2B"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="Scroll_PreviewMouseWheel"
                      Cursor="SizeAll"
                      MouseLeftButtonDown="Scroll_MouseLeftButtonDown"
                      MouseLeftButtonUp="Scroll_MouseLeftButtonUp"
                      MouseMove="Scroll_MouseMove">
            <Image x:Name="Img" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.LayoutTransform>
                    <ScaleTransform x:Name="Scale"/>
                </Image.LayoutTransform>
            </Image>
        </ScrollViewer>
    </DockPanel>
</Window>
